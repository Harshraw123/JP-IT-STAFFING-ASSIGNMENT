# LinkedIn credentials
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Gmail credentials (use an App Password, not your regular password)
# https://support.google.com/accounts/answer/185833
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Browser mode: set to "true" for headless, "false" to watch the browser (recommended during development)
HEADLESS=false

# Path to your resume PDF
RESUME_PATH=./resume.pdf

# Delay between emails in milliseconds (2-3 seconds recommended)
EMAIL_DELAY_MS=2500

# Applicant details used in the email body
APPLICANT_NAME=Your Full Name
APPLICANT_PHONE=+1-555-123-4567
APPLICANT_LINKEDIN=https://www.linkedin.com/in/your-profile
